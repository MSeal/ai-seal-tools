{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-seal-tools/voice/proposal/v1",
  "title": "Voice Analysis Proposal v1",
  "description": "An analysis proposal awaiting human review. Generated by /voice-analyze, consumed by /voice-review. Lives at ~/.config/ai-seal-tools/voice/proposals/<timestamp>.yaml; never source-content-bearing — descriptors and exemplars passed through scrub validation before this file was written.",
  "type": "object",
  "required": [
    "schema_version",
    "proposal_id",
    "created_at",
    "source_hash",
    "source_word_count",
    "classification",
    "proposed_stats",
    "proposed_descriptors",
    "candidate_exemplars",
    "scrub_findings",
    "review_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "proposal_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "source_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_word_count": { "type": "integer", "minimum": 0 },
    "classification": { "$ref": "#/$defs/classification" },
    "override_audience": {
      "type": "string",
      "description": "If the CLI was invoked with --audience, this records the user's override. The reviewer should treat the override as authoritative."
    },
    "override_doc_type": {
      "type": "string",
      "enum": ["polished", "draft", "outline", "chat"]
    },
    "proposed_stats": {
      "type": "object",
      "description": "Output of the deterministic stats extractor. Validated against the profile-v1 stats sub-schema by the reviewer."
    },
    "proposed_descriptors": {
      "type": "object",
      "description": "Output of the descriptor extractor (LLM). Pre-scrubbed against the source."
    },
    "candidate_exemplars": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate_exemplar" }
    },
    "scrub_findings": {
      "type": "array",
      "description": "Any scrub-validator findings raised during proposal generation. Empty list means everything passed clean.",
      "items": { "$ref": "#/$defs/scrub_finding" }
    },
    "review_status": {
      "enum": ["pending", "in_progress", "accepted", "rejected"]
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "classification": {
      "type": "object",
      "required": [
        "audience",
        "audience_confidence",
        "audience_alternates",
        "doc_type",
        "doc_type_confidence",
        "axis_estimates",
        "reasoning"
      ],
      "additionalProperties": false,
      "properties": {
        "audience": { "type": "string" },
        "audience_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "audience_alternates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "doc_type": { "enum": ["polished", "draft", "outline", "chat"] },
        "doc_type_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "axis_estimates": {
          "type": "object",
          "required": ["formality", "technical_density", "brevity", "warmth"],
          "additionalProperties": false,
          "properties": {
            "formality": { "type": "number", "minimum": 0, "maximum": 1 },
            "technical_density": { "type": "number", "minimum": 0, "maximum": 1 },
            "brevity": { "type": "number", "minimum": 0, "maximum": 1 },
            "warmth": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "reasoning": { "type": "string" }
      }
    },
    "candidate_exemplar": {
      "type": "object",
      "required": ["id", "pattern_id", "pattern", "synthetic", "when_to_use", "source_hash", "scrub_status"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^ex_[a-z0-9_]+$" },
        "pattern_id": { "type": "string" },
        "pattern": { "type": "string" },
        "synthetic": { "type": "string" },
        "when_to_use": { "type": "string" },
        "source_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "scrub_status": { "enum": ["passed", "flagged"] },
        "scrub_findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/scrub_finding" }
        }
      }
    },
    "scrub_finding": {
      "type": "object",
      "required": ["rule", "snippet", "detail", "where"],
      "additionalProperties": false,
      "properties": {
        "rule": { "type": "string" },
        "snippet": { "type": "string" },
        "detail": { "type": "string" },
        "where": {
          "type": "string",
          "description": "Which part of the proposal raised this: 'descriptors:<field>' or 'exemplar:<id>'."
        }
      }
    }
  }
}
