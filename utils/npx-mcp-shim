#!/usr/bin/env bash
# npx-mcp-shim — `npx` shim installed onto the MCP server's spawn PATH
# ahead of the real `npx`. Intercepts MCP package launches that need
# extra flags we can't put directly into `.mcp.json` args (because the
# Confluent MDM allowlist literal-matches `command` + `args`). Passes
# every other npx invocation through unchanged.
#
# Why this exists: the MDM allowlist entry for Playwright is exactly
# `["npx", "@playwright/mcp@latest"]`. Adding `--user-data-dir` or
# `--headless` to those args would break the literal match and Claude
# Code would silently refuse to spawn the server. Adding flags via a
# rename-the-wrapper command (`playwright-mcp-with-profile serve`)
# would require a new MDM allowlist entry — friction we don't need
# because PATH interception is an explicitly-supported pattern (env
# overrides are unrestricted; PATH ordering is intentional).
#
# Installation: install_skills.py symlinks this script to
# <shim-dir>/npx and prepends <shim-dir> to env.PATH for every MCP
# server entry in `.mcp.json`. The shim is invisible to the user's
# regular shell — only MCP-spawned `npx` calls hit it. The shim walks
# PATH past its own dir to find the real `npx` for the actual exec.
#
# Currently-intercepted packages:
#   @playwright/mcp@*   →  adds `--user-data-dir <profile>` and
#                          `--headless` (profile defaults to
#                          ~/.config/ai-seal-tools/playwright-profile;
#                          override with $PLAYWRIGHT_MCP_PROFILE_DIR)
#
# Add new interceptions by extending the `case` block below.

set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Walk PATH for the next `npx` that isn't in our shim dir.
REAL_NPX=""
IFS=':' read -ra PATH_PARTS <<< "${PATH:-}"
for dir in "${PATH_PARTS[@]}"; do
    [ -z "$dir" ] && continue
    # Canonicalize so symlinked PATH entries don't confuse the self-check.
    resolved_dir="$(cd "$dir" 2>/dev/null && pwd || true)"
    [ -z "$resolved_dir" ] && continue
    [ "$resolved_dir" = "$SELF_DIR" ] && continue
    if [ -x "$dir/npx" ]; then
        REAL_NPX="$dir/npx"
        break
    fi
done

if [ -z "$REAL_NPX" ]; then
    echo "npx-mcp-shim: no real npx found on PATH past $SELF_DIR" >&2
    echo "  PATH: ${PATH:-<empty>}" >&2
    exit 127
fi

# Detect which package is being launched (scan all args because flags
# like `-y` come before the package name: `npx -y @playwright/mcp@latest`).
PKG=""
for arg in "$@"; do
    case "$arg" in
        @playwright/mcp@*|@playwright/mcp)
            PKG="playwright"
            break
            ;;
    esac
done

case "$PKG" in
    playwright)
        PROFILE_DIR="${PLAYWRIGHT_MCP_PROFILE_DIR:-$HOME/.config/ai-seal-tools/playwright-profile}"
        mkdir -p "$PROFILE_DIR"
        # Insert injected flags immediately after the package name so
        # they reach the playwright-mcp CLI rather than npx itself.
        NEW_ARGS=()
        INJECTED=0
        for arg in "$@"; do
            NEW_ARGS+=("$arg")
            if [ "$INJECTED" -eq 0 ]; then
                case "$arg" in
                    @playwright/mcp@*|@playwright/mcp)
                        NEW_ARGS+=("--user-data-dir" "$PROFILE_DIR" "--headless")
                        INJECTED=1
                        ;;
                esac
            fi
        done
        exec "$REAL_NPX" "${NEW_ARGS[@]}"
        ;;
    *)
        # Transparent passthrough.
        exec "$REAL_NPX" "$@"
        ;;
esac
